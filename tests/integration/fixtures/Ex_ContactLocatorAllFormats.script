%
%   ContactLocator output-format capture script.
%
%   Adapted from samples/Ex_Contact_Location_Station_Mask.script.
%   FOV / Antenna hardware stripped - irrelevant for output-format capture
%   and keeps the run portable. Emits all six ReportFormat variants plus
%   ReportTimeFormat coverage (UTCGregorian, UTCMJD, ISOYD) and an
%   IntervalStepSize=0 case for the AzEl variants.
%

Create Spacecraft Sat
Sat.DateFormat       = UTCGregorian
Sat.Epoch            = '9 Jan 2010 16:00:00.000'
Sat.CoordinateSystem = EarthMJ2000Eq
Sat.DisplayStateType = Keplerian
Sat.SMA              = 16678.14
Sat.ECC              = 0.00
Sat.INC              = 0
Sat.RAAN             = 0
Sat.AOP              = 0
Sat.TA               = 0


Create GroundStation AthGS
AthGS.CentralBody           = Earth
AthGS.HorizonReference      = Ellipsoid
AthGS.StateType             = Spherical
AthGS.Location1             = 33.9519
AthGS.Location2             = 276.6424
AthGS.Location3             = 0
AthGS.Id                    = 'AthGS'
AthGS.MinimumElevationAngle = 5

Create GroundStation HreGS
HreGS.CentralBody           = Earth
HreGS.HorizonReference      = Ellipsoid
HreGS.StateType             = Spherical
HreGS.Location1             = 50.7753
HreGS.Location2             = 6.0839
HreGS.Location3             = 0
HreGS.Id                    = 'HreGS'
HreGS.MinimumElevationAngle = 5

Create GroundStation GSFC
GSFC.CentralBody           = Earth
GSFC.HorizonReference      = Ellipsoid
GSFC.StateType             = Spherical
GSFC.Location1             = 38.9949
GSFC.Location2             = 283.1477
GSFC.Location3             = 0
GSFC.Id                    = 'GSFC'
GSFC.MinimumElevationAngle = 5


Create ForceModel fm
fm.CentralBody                      = Earth
fm.PrimaryBodies                    = {Earth}
fm.GravityField.Earth.PotentialFile = 'JGM2.cof'
fm.GravityField.Earth.Degree        = 0
fm.GravityField.Earth.Order         = 0
fm.GravityField.Earth.TideModel     = 'None'
fm.Drag.AtmosphereModel             = None
fm.PointMasses                      = {}
fm.RelativisticCorrection           = Off
fm.SRP                              = Off
fm.ErrorControl                     = None

Create Propagator prop
prop.FM   = fm
prop.Type = RungeKutta89


% --- one resource per ReportFormat ---

Create ContactLocator LegacyCL
LegacyCL.Target               = Sat
LegacyCL.Observers            = {AthGS, HreGS, GSFC}
LegacyCL.Filename             = 'CL_Legacy.txt'

Create ContactLocator ContactRangeCL
ContactRangeCL.Target               = Sat
ContactRangeCL.Observers            = {AthGS, HreGS, GSFC}
ContactRangeCL.Filename             = 'CL_ContactRange.txt'
ContactRangeCL.ReportFormat         = 'ContactRangeReport'
ContactRangeCL.ReportTimeFormat     = 'UTCGregorian'

Create ContactLocator MaxElevCL
MaxElevCL.Target               = Sat
MaxElevCL.Observers            = {AthGS, HreGS, GSFC}
MaxElevCL.Filename             = 'CL_MaxElev.txt'
MaxElevCL.ReportFormat         = 'SiteViewMaxElevationReport'
MaxElevCL.ReportTimeFormat     = 'UTCGregorian'

Create ContactLocator MaxElevRangeCL
MaxElevRangeCL.Target               = Sat
MaxElevRangeCL.Observers            = {AthGS, HreGS, GSFC}
MaxElevRangeCL.Filename             = 'CL_MaxElevRange.txt'
MaxElevRangeCL.ReportFormat         = 'SiteViewMaxElevationRangeReport'
MaxElevRangeCL.ReportTimeFormat     = 'UTCGregorian'

% AzEl variants - stepped (interpolated) and step=0 (edge-only) cases.
Create ContactLocator AzElRangeCL
AzElRangeCL.Target               = Sat
AzElRangeCL.Observers            = {AthGS, HreGS, GSFC}
AzElRangeCL.Filename             = 'CL_AzElRange_iso.txt'
AzElRangeCL.IntervalStepSize     = 60
AzElRangeCL.ReportFormat         = 'AzimuthElevationRangeReport'
AzElRangeCL.ReportTimeFormat     = 'ISOYD'

Create ContactLocator AzElRangeRRCL
AzElRangeRRCL.Target               = Sat
AzElRangeRRCL.Observers            = {AthGS, HreGS, GSFC}
AzElRangeRRCL.Filename             = 'CL_AzElRangeRR_mjd.txt'
AzElRangeRRCL.IntervalStepSize     = 120
AzElRangeRRCL.ReportFormat         = 'AzimuthElevationRangeRangeRateReport'
AzElRangeRRCL.ReportTimeFormat     = 'UTCMJD'


BeginMissionSequence

Propagate prop(Sat) {Sat.ElapsedDays = 1}
