%  Minimal LEO mission used by the integration suite to exercise the
%  EphemerisFile (CCSDS-OEM) writer and round-trip parser. Avoids
%  OpenFramesInterface / OrbitView so it parses headlessly through gmatpy.
%  6-hour propagation at 60 s steps gives ~361 ephemeris records, plus a
%  paired ReportFile so the same sample exercises both writers.

Create Spacecraft Sat
Sat.DateFormat = UTCGregorian
Sat.Epoch = '01 Jan 2026 12:00:00.000'
Sat.CoordinateSystem = EarthMJ2000Eq
Sat.DisplayStateType = Keplerian
Sat.SMA = 7000
Sat.ECC = 0.001
Sat.INC = 28.5
Sat.RAAN = 75
Sat.AOP = 90
Sat.TA = 0

Create ForceModel FM
FM.CentralBody = Earth
FM.PrimaryBodies = {Earth}

Create Propagator Prop
Prop.FM = FM
Prop.Type = PrinceDormand78
Prop.InitialStepSize = 60
Prop.Accuracy = 1e-9

Create EphemerisFile EF
EF.Spacecraft = Sat
EF.Filename = 'leo_ephemeris.oem'
EF.FileFormat = CCSDS-OEM
EF.EpochFormat = UTCGregorian
EF.WriteEphemeris = true
EF.StepSize = 60

Create ReportFile RF
RF.Filename = 'leo_state.txt'
RF.Add = {Sat.UTCGregorian, Sat.X, Sat.Y, Sat.Z, Sat.VX, Sat.VY, Sat.VZ}
RF.WriteHeaders = true

BeginMissionSequence
Propagate Prop(Sat) {Sat.ElapsedSecs = 21600}
