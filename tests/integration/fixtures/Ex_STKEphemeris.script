%  Minimal LEO mission used by the integration suite to exercise the
%  EphemerisFile (STK-TimePosVel) writer and round-trip parser. Mirrors
%  Ex_LEOEphemeris but emits the STK text format instead of CCSDS-OEM.
%  Avoids OpenFramesInterface / OrbitView so it parses headlessly through
%  gmatpy. 6-hour propagation interpolated onto 60 s ephemeris cadence ->
%  361 records. EphemerisFile-only so the golden comparison stays tight on
%  fixed-cadence offsets that don't drift across platforms.

Create Spacecraft Sat
Sat.DateFormat = UTCGregorian
Sat.Epoch = '01 Jan 2026 12:00:00.000'
Sat.CoordinateSystem = EarthMJ2000Eq
Sat.DisplayStateType = Keplerian
Sat.SMA = 7000
Sat.ECC = 0.001
Sat.INC = 28.5
Sat.RAAN = 75
Sat.AOP = 90
Sat.TA = 0

Create ForceModel FM
FM.CentralBody = Earth
FM.PrimaryBodies = {Earth}

Create Propagator Prop
Prop.FM = FM
Prop.Type = PrinceDormand78
Prop.InitialStepSize = 60
Prop.Accuracy = 1e-9

Create EphemerisFile EF
EF.Spacecraft = Sat
EF.Filename = 'leo_ephemeris.e'
EF.FileFormat = STK-TimePosVel
EF.EpochFormat = UTCGregorian
EF.WriteEphemeris = true
EF.StepSize = 60

BeginMissionSequence
Propagate Prop(Sat) {Sat.ElapsedSecs = 21600}
